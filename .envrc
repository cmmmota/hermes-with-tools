source_env_if_exists .envrc.local

if [ -n "$GH_TOKEN" ]; then
  # Only set if not already set to this value to avoid unnecessary writes
  current_helper=$(git config --local credential.helper 2>/dev/null || true)
  target_helper='!f() { echo "username=x-access-token"; echo "password=$GH_TOKEN"; }; f'
  if [ "$current_helper" != "$target_helper" ]; then
    git config --local credential.helper "$target_helper"
  fi
fi